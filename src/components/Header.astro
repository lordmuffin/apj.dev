---
import { site } from '../site.config';
const { current } = Astro.props as { current?: string };
---
<header class="site-header">
  <a href="/" class="mark">{site.shortMark}<span>.</span>jackson</a>
  <nav>
    <a href="/#work" class:list={[current === 'work' && 'active']}>Work</a>
    <a href="/blog" class:list={[current === 'blog' && 'active']}>Writing</a>
    <a href="/about" class:list={[current === 'about' && 'active']}>About</a>
    <a href="/#contact" class="cta">Get in touch</a>
  </nav>
</header>
